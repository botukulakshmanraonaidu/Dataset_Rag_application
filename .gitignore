# ============================================================
#  Enterprise Document RAG — .gitignore
# ============================================================

# ─────────────────────────────────────────
#  Python / Backend
# ─────────────────────────────────────────

# Virtual environments (root + backend)
venv/
.venv/
env/
backend/venv/
backend/.venv/

# Python bytecode & cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# Unit test / coverage
.coverage
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
coverage.xml
*.cover

# MyPy type checker
.mypy_cache/
.dmypy.json

# ─────────────────────────────────────────
#  Environment & Secrets  ⚠️  NEVER commit these
# ─────────────────────────────────────────
.env
.env.*
!.env.example      # keep the example template if you have one
*.pem
*.key
secrets.json
config/secrets.*

# ─────────────────────────────────────────
#  RAG / Vector Store — Generated data
# ─────────────────────────────────────────

# FAISS index (auto-generated, can be rebuilt)
backend/faiss_index/

# BM25 serialized chunks (auto-generated)
backend/bm25_chunks.json

# Uploaded / ingested source documents
backend/data/

# Any other large model or index artefacts
*.bin
*.pkl
*.faiss
*.index

# ─────────────────────────────────────────
#  Node.js / Frontend (React + Vite)
# ─────────────────────────────────────────

# Dependencies
node_modules/
frontend/node_modules/

# Production build output
frontend/dist/
frontend/build/

# Vite cache
frontend/.vite/
.vite/

# npm / yarn / pnpm lock files (keep package-lock.json but ignore others)
# Uncomment the line below if you want to ignore package-lock too:
# package-lock.json
yarn.lock
pnpm-lock.yaml
.yarn/

# ─────────────────────────────────────────
#  IDE & Editor
# ─────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ─────────────────────────────────────────
#  Logs
# ─────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────
#  Miscellaneous
# ─────────────────────────────────────────
*.tmp
*.bak
*.swp
.cache/
archive/
archive.zip

